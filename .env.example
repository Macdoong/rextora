# ==============================================================================
# Rextora environment configuration (example only — copy to .env.local and fill in)
# NEVER commit a file with real secrets. This file must only contain placeholders.
# ==============================================================================

# --- Binance Futures (read-only only by default) -------------------------
# Read-only endpoints work with any key. Real order execution is blocked in
# PAPER mode and gated behind the full LIVE safety checklist in LIVE mode.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_BASE_URL=https://testnet.binancefuture.com
BINANCE_FUTURES_BASE_URL=https://testnet.binancefuture.com

# --- Telegram assistant ----------------------------------------------------
# Used only for connectivity tests and (once fully wired) risk/entry/exit
# notifications. Tokens are never logged or returned from API routes.
TG_TOKEN=
TG_CHAT_ID=

# --- Trading mode & LIVE gating --------------------------------------------
# Rextora always boots in PAPER regardless of this value; REXTORA_DEFAULT_MODE
# only expresses operator intent and never bypasses the LIVE safety gate.
REXTORA_DEFAULT_MODE=PAPER

# Master LIVE approval switch. Must be explicitly set to true AND every other
# LIVE gate (see src/lib/rextora/liveSafetyGate.ts) must also pass before any
# real order can be placed.
REXTORA_LIVE_APPROVED=false

# Exact phrase the operator must submit to confirm LIVE start intent.
# Leave empty to keep LIVE permanently blocked even if REXTORA_LIVE_APPROVED=true.
REXTORA_LIVE_CONFIRMATION_TEXT=

# --- Risk limits -------------------------------------------------------------
REXTORA_MAX_DAILY_LOSS_PCT=-5
REXTORA_MAX_TOTAL_LOSS_PCT=-10
REXTORA_MAX_CONSECUTIVE_LOSSES=3
REXTORA_MAX_POSITIONS=3
REXTORA_MAX_LEVERAGE=2.5
REXTORA_MAX_TRADES_PER_DAY=20
REXTORA_MIN_EXPECTED_EDGE_PCT=0.3
REXTORA_SAFETY_MARGIN_PCT=0.14

# LIVE start is blocked unless server-side TP/SL orders are required and active.
REXTORA_SERVER_TPSL_REQUIRED=true
